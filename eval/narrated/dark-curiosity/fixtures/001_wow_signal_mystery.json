  "script": {
    "title": "The signal that appeared once",
    "estimatedSeconds": 32,
    "beats": [
      {
        "id": "beat_hook",
        "role": "hook",
        "spokenText": "In 1977, one radio signal looked so unusual that an astronomer wrote one word: Wow.",
        "onScreenText": "A signal appeared once",
        "claimIds": ["claim_recorded"]
      },
      {
        "id": "beat_context",
        "role": "context",
        "spokenText": "It arrived near a frequency researchers considered promising for interstellar communication and lasted seventy-two seconds.",
        "onScreenText": "72 seconds near a notable frequency",
        "claimIds": ["claim_frequency"]
      },
      {
        "id": "beat_evidence",
        "role": "evidence",
        "spokenText": "Its strength rose and fell as the telescope beam crossed the source, making ordinary local interference less convincing.",
        "onScreenText": "The signal followed the telescope beam",
        "claimIds": ["claim_beam-shape"]
      },
      {
        "id": "beat_turn",
        "role": "turn",
        "spokenText": "But later searches never verified the same signal again, and no confirmed transmission has explained it.",
        "onScreenText": "It never repeated",
        "claimIds": ["claim_not-repeated"]
      },
      {
        "id": "beat_payoff",
        "role": "payoff",
        "spokenText": "The honest answer is not aliens. It is one strong unexplained candidate that left no repeatable proof.",
        "onScreenText": "Unexplained is not proof",
        "claimIds": ["claim_conclusion"]
      }
    ],
