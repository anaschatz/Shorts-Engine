{
  "name": "shortsengine-static-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Hardened local prototype for the ShortsEngine AI football highlights short-form studio.",
  "scripts": {
    "build": "node tests/build-smoke.mjs",
    "branch:doctor": "node tools/release/check-branch-protection.mjs",
    "branch:proof": "node tools/release/write-branch-protection-proof.mjs",
    "branch:setup": "node tools/release/print-branch-ruleset-setup.mjs",
    "brain:find": "node tools/openviking-lite.mjs find",
    "brain:health": "node tools/openviking-lite.mjs health",
    "brain:init": "node tools/openviking-lite.mjs init",
    "brain:tree": "node tools/openviking-lite.mjs tree",
    "ci:reports": "node demo/validate-ci-reports.mjs",
    "demo:browser": "node demo/run-browser-smoke.mjs",
    "demo:browser:ci": "node demo/run-playwright-smoke.mjs",
    "demo:browser:e2e": "node demo/run-playwright-smoke.mjs",
    "demo:browser:install": "playwright install chromium",
    "demo:compare": "node demo/run-side-by-side-review.mjs",
    "demo:e2e": "node demo/run-smoke.mjs",
    "demo:fixture": "node demo/create-fixture.mjs",
    "demo:manual": "node demo/print-manual.mjs",
    "demo:smoke": "node demo/run-smoke.mjs",
    "demo:youtube:live": "node demo/run-youtube-live-e2e.mjs",
    "dev": "node server/app.cjs",
    "env:check": "node tools/release/check-environment.mjs",
    "eval": "node eval/run-eval.mjs",
    "eval:ci": "node eval/run-eval.mjs --threshold=80",
    "eval:reference": "node eval/run-reference-review.mjs",
    "feedback:summary": "node eval/run-feedback-summary.mjs",
    "github:doctor": "node tools/release/check-github-cli.mjs",
    "github:setup": "node tools/release/print-github-cli-setup.mjs",
    "integration:cloud": "node scripts/run-real-cloud-integration.mjs",
    "lint": "node tests/static-lint.mjs",
    "release:check": "node tools/release/verify-release-gate.mjs",
    "release:evidence": "node tools/release/write-release-evidence.mjs",
    "release:readiness": "node tools/release/check-release-readiness.mjs",
    "remote:ci": "node tools/release/check-remote-ci.mjs",
    "remote:ci:proof": "node tools/release/write-remote-ci-proof.mjs",
    "render:check": "node tools/release/check-render-staging.mjs",
    "render:manual": "node tools/release/print-render-staging-checklist.mjs",
    "render:proof": "node tools/release/render-staging-proof.mjs",
    "review:compare": "node eval/run-review-comparison.mjs",
    "review:register": "node eval/run-review-registration.mjs",
    "review:summary": "node eval/run-review-summary.mjs",
    "staging:check": "node tools/release/check-staging-readiness.mjs",
    "staging:deploy": "node tools/release/staging-deploy.mjs",
    "staging:smoke:cleanup": "node tools/release/cleanup-staging-full-smoke.mjs",
    "staging:smoke:full": "node tools/release/check-staging-full-smoke.mjs",
    "staging:smoke": "node tools/release/check-staging-smoke.mjs",
    "start": "node server/app.cjs",
    "test": "node --test --test-concurrency=1 tests/*.test.js tests/*.test.mjs tests/*.test.cjs",
    "youtube:doctor": "node tools/release/check-youtube-ingest.mjs",
    "youtube:e2e:local": "node demo/run-youtube-live-e2e.mjs",
    "youtube:proof": "node demo/run-youtube-live-e2e.mjs",
    "youtube:proof:operator": "node demo/run-youtube-live-e2e.mjs --operator",
    "youtube:smoke": "node demo/run-youtube-smoke.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
