# ShortsEngine staging environment example.
# Copy to `.env` in your deployment platform if needed. Never commit real `.env` files.

# App/runtime
PORT=4175

# Upload/media limits
MATCHCUTS_MAX_UPLOAD_BYTES=262144000
MATCHCUTS_MAX_DURATION_SECONDS=1800

# FFmpeg/render limits
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
MATCHCUTS_RENDER_TIMEOUT_MS=300000
MATCHCUTS_ANALYSIS_TIMEOUT_MS=45000

# Worker/job settings
MATCHCUTS_WORKER_POLL_INTERVAL_MS=0
MATCHCUTS_WORKER_SHUTDOWN_TIMEOUT_MS=10000
MATCHCUTS_WORKER_RETRY_INITIAL_DELAY_MS=1000
MATCHCUTS_WORKER_RETRY_MAX_DELAY_MS=30000
MATCHCUTS_WORKER_RETRY_MAX_ATTEMPTS=2
MATCHCUTS_ARTIFACT_CLEANUP_INTERVAL_MS=0

# Storage/artifact adapter
MATCHCUTS_STORAGE_ADAPTER=local
MATCHCUTS_STORAGE_BUCKET=
MATCHCUTS_STORAGE_REGION=
MATCHCUTS_STORAGE_ENDPOINT=
MATCHCUTS_STORAGE_FORCE_PATH_STYLE=false
MATCHCUTS_STORAGE_SIGNED_URL_TTL_SECONDS=300
MATCHCUTS_MULTIPART_THRESHOLD_BYTES=67108864
MATCHCUTS_MULTIPART_PART_SIZE_BYTES=16777216
MATCHCUTS_ARTIFACT_CLEANUP_MAX_AGE_SECONDS=86400
MATCHCUTS_ARTIFACT_CLEANUP_MAX_PER_RUN=100

# Storage credentials. Leave empty for local/mock staging.
MATCHCUTS_STORAGE_ACCESS_KEY_ID=
MATCHCUTS_STORAGE_SECRET_ACCESS_KEY=
MATCHCUTS_STORAGE_SESSION_TOKEN=

# Persistence adapter
MATCHCUTS_PERSISTENCE_ADAPTER=local
MATCHCUTS_SQLITE_FILE=shortsengine.sqlite

# Transcription/AI provider
MATCHCUTS_TRANSCRIPTION_PROVIDER=mock
MATCHCUTS_TRANSCRIPTION_TIMEOUT_MS=60000
MATCHCUTS_TRANSCRIPTION_RETRIES=1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_API_KEY=

# Cloud integration. Keep disabled unless running explicit real cloud tests.
MATCHCUTS_RUN_REAL_CLOUD_TESTS=0

# Staging deployment/readiness. Keep provider none until a real deploy step exists.
SHORTSENGINE_DEPLOY_TARGET=local
SHORTSENGINE_STAGING_DEPLOY_PROVIDER=none
SHORTSENGINE_STAGING_URL=
SHORTSENGINE_STAGING_ALLOW_LOCAL_URL=0
SHORTSENGINE_STAGING_SMOKE_TIMEOUT_MS=30000
SHORTSENGINE_STAGING_SMOKE_RETRIES=2
SHORTSENGINE_STAGING_DEPLOY_TOKEN=

# Browser/demo/CI flags
DEMO_SMOKE_PORT=
DEMO_SMOKE_TIMEOUT_MS=120000
PLAYWRIGHT_SMOKE_PORT=
PLAYWRIGHT_SMOKE_JOB_TIMEOUT_MS=120000
PLAYWRIGHT_SMOKE_TIMEOUT_MS=120000
SHORTSENGINE_BROWSER_E2E_ALLOW_SKIP=0
SHORTSENGINE_BROWSER_E2E_RETENTION_MAX=20
SHORTSENGINE_BROWSER_E2E_TRACE=0
SHORTSENGINE_BROWSER_E2E_VIDEO=0
SHORTSENGINE_CI_REPORT_MAX_AGE_MS=7200000
