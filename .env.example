# ShortsEngine staging environment example.
# Copy to `.env` in your deployment platform if needed. Never commit real `.env` files.

# App/runtime
PORT=4175

# Auth. Production/staging must use operator mode with a strong secret from the platform secret manager.
# Local anonymous mode is only for explicit local demos/tests; never enable it in staging/production.
SHORTSENGINE_ENVIRONMENT=local
SHORTSENGINE_AUTH_MODE=operator
SHORTSENGINE_OPERATOR_ID=operator
SHORTSENGINE_OPERATOR_AUTH_TOKEN=

# Upload/media limits
MATCHCUTS_MAX_UPLOAD_BYTES=262144000
MATCHCUTS_MAX_DURATION_SECONDS=1800

# YouTube URL ingest. Disabled by default; enable only with explicit rights/downloader policy.
SHORTSENGINE_YOUTUBE_INGEST_ENABLED=0
SHORTSENGINE_YOUTUBE_AUTHORIZED_IMPORT_ENABLED=0
SHORTSENGINE_YOUTUBE_DOWNLOADER_BIN=yt-dlp
SHORTSENGINE_YOUTUBE_PLAYER_CLIENT=
SHORTSENGINE_YOUTUBE_INGEST_TIMEOUT_MS=120000
SHORTSENGINE_YOUTUBE_DOWNLOAD_TIMEOUT_MS=
SHORTSENGINE_YOUTUBE_DOWNLOADER_OUTPUT_BYTES=65536
SHORTSENGINE_YOUTUBE_FORMAT_SELECTOR=bv*[ext=mp4]+ba[ext=m4a]/b[ext=mp4]/best
SHORTSENGINE_YOUTUBE_FALLBACK_FORMAT_SELECTOR=best[ext=mp4]/best
SHORTSENGINE_YOUTUBE_DOWNLOAD_ATTEMPTS=2
SHORTSENGINE_YOUTUBE_RETRY_BACKOFF_MS=500
SHORTSENGINE_SOURCE_CACHE_ENABLED=0
SHORTSENGINE_SOURCE_CACHE_DIR=
SHORTSENGINE_SOURCE_CACHE_REQUIRE_CHECKSUM=0
SHORTSENGINE_SOURCE_CACHE_MAX_BYTES=262144000
SHORTSENGINE_YOUTUBE_PROGRESS_HEARTBEAT_MS=5000
SHORTSENGINE_YOUTUBE_NO_PROGRESS_TIMEOUT_MS=45000
SHORTSENGINE_YOUTUBE_DOCTOR_URL=
SHORTSENGINE_YOUTUBE_DOCTOR_TIMEOUT_MS=5000
SHORTSENGINE_YOUTUBE_SMOKE=0
SHORTSENGINE_YOUTUBE_SMOKE_URL=
SHORTSENGINE_YOUTUBE_SMOKE_BASE_URL=
SHORTSENGINE_YOUTUBE_SMOKE_ALLOWED_IDS=
SHORTSENGINE_YOUTUBE_SMOKE_ALLOW_UNLISTED=0
SHORTSENGINE_YOUTUBE_SMOKE_TIMEOUT_MS=120000
SHORTSENGINE_YOUTUBE_SMOKE_REQUEST_TIMEOUT_MS=120000
SHORTSENGINE_YOUTUBE_SMOKE_JOB_TIMEOUT_MS=90000
SHORTSENGINE_YOUTUBE_SMOKE_POLL_INTERVAL_MS=750
SHORTSENGINE_YOUTUBE_SMOKE_DOWNLOAD_MAX_BYTES=83886080
SHORTSENGINE_YOUTUBE_LIVE_E2E=0
SHORTSENGINE_YOUTUBE_LIVE_E2E_RIGHTS_CONFIRMED=0
SHORTSENGINE_YOUTUBE_LIVE_E2E_URL=
SHORTSENGINE_YOUTUBE_LIVE_E2E_PORT=
SHORTSENGINE_YOUTUBE_LIVE_E2E_TIMEOUT_MS=1800000
SHORTSENGINE_YOUTUBE_LIVE_E2E_DOWNLOAD_TIMEOUT_MS=
SHORTSENGINE_YOUTUBE_LIVE_E2E_BROWSER=0

# FFmpeg/render limits
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
MATCHCUTS_RENDER_TIMEOUT_MS=300000
MATCHCUTS_ANALYSIS_TIMEOUT_MS=45000

# Automatic Real-ESRGAN clean-layer enhancement through the managed Python/MPS runtime.
SHORTSENGINE_VIDEO_ENHANCEMENT_ENABLED=auto
SHORTSENGINE_VIDEO_ENHANCEMENT_REQUIRED=1
SHORTSENGINE_VIDEO_ENHANCEMENT_PROVIDER=realesrgan-python
SHORTSENGINE_REALESRGAN_BIN=managed
SHORTSENGINE_REALESRGAN_PYTHON_BIN=
SHORTSENGINE_REALESRGAN_MODEL_DIR=
SHORTSENGINE_REALESRGAN_MODEL_PATH=
SHORTSENGINE_REALESRGAN_MODEL=realesrgan-x4plus
SHORTSENGINE_REALESRGAN_SCALE=4
SHORTSENGINE_REALESRGAN_TILE=0
SHORTSENGINE_REALESRGAN_DEVICE=auto
SHORTSENGINE_VIDEO_ENHANCEMENT_FPS=12
SHORTSENGINE_VIDEO_ENHANCEMENT_TIMEOUT_MS=1800000

# Scoreboard OCR. Deterministic fallback by default; local runtime is operator-enabled.
SHORTSENGINE_SCOREBOARD_OCR_ENABLED=0
SHORTSENGINE_SCOREBOARD_OCR_PROVIDER=deterministic
SHORTSENGINE_SCOREBOARD_OCR_BIN=tesseract
SHORTSENGINE_SCOREBOARD_OCR_TIMEOUT_MS=10000
SHORTSENGINE_SCOREBOARD_OCR_QA_ARTIFACTS=0
SHORTSENGINE_SCOREBOARD_OCR_QA_ARTIFACT_RETENTION=8
SHORTSENGINE_OCR_QA_ARTIFACTS=0
SHORTSENGINE_OCR_QA_ARTIFACT_RETENTION=8

# Optional action tracking. Disabled by default; OpenCV/Python are never required for tests/demo.
SHORTSENGINE_TRACKING_PROVIDER=safe
SHORTSENGINE_OPENCV_TRACKING_ENABLED=0
SHORTSENGINE_OPENCV_PYTHON_BIN=python3
SHORTSENGINE_OPENCV_TRACKING_TIMEOUT_MS=3500

# Worker/job settings
MATCHCUTS_WORKER_POLL_INTERVAL_MS=0
MATCHCUTS_WORKER_SHUTDOWN_TIMEOUT_MS=10000
MATCHCUTS_WORKER_RETRY_INITIAL_DELAY_MS=1000
MATCHCUTS_WORKER_RETRY_MAX_DELAY_MS=30000
MATCHCUTS_WORKER_RETRY_MAX_ATTEMPTS=2
MATCHCUTS_ARTIFACT_CLEANUP_INTERVAL_MS=0

# Storage/artifact adapter
MATCHCUTS_STORAGE_ADAPTER=local
MATCHCUTS_STORAGE_BUCKET=
MATCHCUTS_STORAGE_REGION=
MATCHCUTS_STORAGE_ENDPOINT=
MATCHCUTS_STORAGE_FORCE_PATH_STYLE=false
MATCHCUTS_STORAGE_SIGNED_URL_TTL_SECONDS=300
MATCHCUTS_MULTIPART_THRESHOLD_BYTES=67108864
MATCHCUTS_MULTIPART_PART_SIZE_BYTES=16777216
MATCHCUTS_ARTIFACT_CLEANUP_MAX_AGE_SECONDS=86400
MATCHCUTS_ARTIFACT_CLEANUP_MAX_PER_RUN=100

# Storage credentials. Leave empty for local/mock staging.
MATCHCUTS_STORAGE_ACCESS_KEY_ID=
MATCHCUTS_STORAGE_SECRET_ACCESS_KEY=
MATCHCUTS_STORAGE_SESSION_TOKEN=

# Persistence adapter
MATCHCUTS_PERSISTENCE_ADAPTER=local
MATCHCUTS_SQLITE_FILE=shortsengine.sqlite

# Transcription/AI provider
MATCHCUTS_TRANSCRIPTION_PROVIDER=mock
MATCHCUTS_TRANSCRIPTION_TIMEOUT_MS=60000
MATCHCUTS_TRANSCRIPTION_RETRIES=1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_API_KEY=
# AI narration. Production synthesis is opt-in and never falls back to mock.
# The operator must separately attest that their provider plan and selected built-in voice permit commercial use.
SHORTSENGINE_TTS_PROVIDER=kokoro_local
SHORTSENGINE_TTS_MODEL=kokoro-v1.0-onnx-f32
SHORTSENGINE_TTS_VOICE=af_heart
SHORTSENGINE_TTS_TIMEOUT_MS=60000
SHORTSENGINE_KOKORO_PYTHON_BIN=
SHORTSENGINE_KOKORO_MODEL_DIR=
SHORTSENGINE_KOKORO_TIMEOUT_MS=120000
SHORTSENGINE_LOCAL_WHISPER_MODE=auto
SHORTSENGINE_LOCAL_WHISPER_PYTHON_BIN=python3
SHORTSENGINE_LOCAL_WHISPER_MODEL=base
SHORTSENGINE_LOCAL_WHISPER_DEVICE=cpu
SHORTSENGINE_LOCAL_WHISPER_COMPUTE_TYPE=int8
SHORTSENGINE_LOCAL_WHISPER_TIMEOUT_MS=180000

# Cloud integration. Keep disabled unless running explicit real cloud tests.
MATCHCUTS_RUN_REAL_CLOUD_TESTS=0

# Staging deployment/readiness. Keep provider none until Render staging is configured.
SHORTSENGINE_DEPLOY_TARGET=local
SHORTSENGINE_STAGING_DEPLOY_PROVIDER=none
SHORTSENGINE_STAGING_SERVICE_ID=
SHORTSENGINE_STAGING_URL=
SHORTSENGINE_STAGING_ALLOW_LOCAL_URL=0
SHORTSENGINE_STAGING_SMOKE_TIMEOUT_MS=30000
SHORTSENGINE_STAGING_SMOKE_RETRIES=2
SHORTSENGINE_STAGING_DEPLOY_TOKEN=
SHORTSENGINE_STAGING_FULL_SMOKE=0
SHORTSENGINE_STAGING_FULL_SMOKE_FIXTURE=demo/fixtures/shortsengine-demo-source.mp4
SHORTSENGINE_STAGING_FULL_SMOKE_TIMEOUT_MS=120000
SHORTSENGINE_STAGING_FULL_SMOKE_JOB_TIMEOUT_MS=90000
SHORTSENGINE_STAGING_FULL_SMOKE_POLL_INTERVAL_MS=750
SHORTSENGINE_STAGING_FULL_SMOKE_DOWNLOAD_MAX_BYTES=83886080
SHORTSENGINE_STAGING_FULL_SMOKE_FIXTURE_MAX_BYTES=33554432
SHORTSENGINE_STAGING_FULL_SMOKE_ALLOW_DEGRADED=0
SHORTSENGINE_STAGING_FULL_SMOKE_CLEANUP=0
SHORTSENGINE_STAGING_FULL_SMOKE_CLEANUP_MAX_AGE_SECONDS=0
SHORTSENGINE_STAGING_FULL_SMOKE_CLEANUP_MAX_COUNT=20

# Browser/demo/CI flags
DEMO_SMOKE_PORT=
DEMO_SMOKE_TIMEOUT_MS=120000
PLAYWRIGHT_SMOKE_PORT=
PLAYWRIGHT_SMOKE_JOB_TIMEOUT_MS=120000
PLAYWRIGHT_SMOKE_TIMEOUT_MS=120000
SHORTSENGINE_BROWSER_E2E_ALLOW_SKIP=0
SHORTSENGINE_BROWSER_E2E_RETENTION_MAX=20
SHORTSENGINE_BROWSER_E2E_TRACE=0
SHORTSENGINE_BROWSER_E2E_VIDEO=0
SHORTSENGINE_CI_REPORT_MAX_AGE_MS=7200000
